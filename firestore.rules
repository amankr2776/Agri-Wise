
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(ownerId) {
      return resource != null && isSignedIn() && request.auth.uid == ownerId;
    }

    function getRole() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data.role : 'Farmer';
    }

    function isExpert() {
      let role = getRole();
      return isSignedIn() && (role == 'Expert' || role == 'Authority');
    }

    // --- Crops Collection ---
    match /crops/{id} { 
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Vehicles Collection ---
    match /vehicles/{vehicleId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Bookings Collection ---
    match /bookings/{bookingId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- Posts & Community Social Hub ---
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isExistingOwner(resource.data.authorId);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
      }
    }

    // --- Feedback & Reviews ---
    match /feedback/{feedbackId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isExistingOwner(resource.data.authorId);
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /pestOutbreaks/{outbreakId} {
      // Alerts are critical intelligence for the entire grid. 
      // Allowing read access to all signed-in users prevents race conditions 
      // during profile synchronization while keeping writes restricted.
      allow read: if isSignedIn();
      allow create, update, delete: if isExpert();
    }
  }
}
