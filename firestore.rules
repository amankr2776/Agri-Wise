rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * KisanMitra National Grid Security Rules
     * 
     * CORE PHILOSOPHY:
     * Reference data is publicly readable to support "Guest Mode".
     * User data and system roles require strict ownership/authorization.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(field) {
      return isSignedIn() && resource != null && resource.data[field] == request.auth.uid;
    }

    function hasRole(roleCollection) {
      return isSignedIn() && exists(/databases/$(database)/documents/$(roleCollection)/$(request.auth.uid));
    }

    function isAdmin() {
      return hasRole('roles_admins');
    }

    function isExpert() {
      return hasRole('roles_experts');
    }

    function isGovOfficial() {
      return hasRole('roles_governmentOfficials');
    }

    // --- COLLECTION RULES ---

    /**
     * @description Reference Data (Crops, Pests, Diseases).
     * Publicly readable by EVERYONE to enable unauthenticated dashboard access.
     */
    match /crops/{cropId} {
      allow read: if true;
      allow write: if isAdmin() || isExpert();
    }

    match /pests/{pestId} {
      allow read: if true;
      allow write: if isAdmin() || isExpert();
    }

    match /diseases/{diseaseId} {
      allow read: if true;
      allow write: if isAdmin() || isExpert();
    }

    /**
     * @description User profiles and role markers.
     */
    match /userProfiles/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    match /roles_admins/{userId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_experts/{userId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_governmentOfficials/{userId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_logisticsProviders/{userId} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    /**
     * @description Market intelligence.
     */
    match /marketPrices/{marketPriceId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() || isGovOfficial();
    }

    match /mandiPrices/{priceId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() || isGovOfficial();
    }

    match /states/{stateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Logistics and transport.
     * Public visibility for vehicles, but bookings require auth.
     */
    match /vehicles/{vehicleId} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && request.resource.data.ownerId == request.auth.uid);
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (resource.data.farmerId == request.auth.uid || hasRole('roles_logisticsProviders'));
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    /**
     * @description Social network.
     */
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isExistingOwner('authorId') || isExpert();
      allow delete: if isExistingOwner('authorId') || isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isExistingOwner('authorId') || isAdmin();
      }
    }

    match /pestOutbreaks/{outbreakId} {
      allow read: if true;
      allow write: if isAdmin() || isExpert() || isGovOfficial();
    }

    /**
     * @description Private user data.
     */
    match /users/{userId}/notifications/{notifId} {
      allow read, write: if isOwner(userId) || isExpert() || isAdmin();
    }
    
    match /users/{userId}/conversations/{convId} {
      allow read, write: if isOwner(userId);
    }

    match /media_public/{mediaId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /users/{userId}/media_private/{mediaId} {
      allow read, write: if isOwner(userId);
    }
  }
}