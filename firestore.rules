
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(ownerId) {
      return resource != null && isSignedIn() && request.auth.uid == ownerId;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isExpert() {
      return isSignedIn() && getRole() == 'Expert';
    }

    function isAuthority() {
      return isSignedIn() && getRole() == 'Authority';
    }

    // --- Crops Collection ---
    match /crops/{id} { 
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Vehicles Collection ---
    match /vehicles/{vehicleId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Bookings Collection ---
    match /bookings/{bookingId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- Posts & Community Social Hub ---
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isExistingOwner(resource.data.authorId);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
      }
    }

    // --- Feedback & Reviews ---
    match /feedback/{feedbackId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isExistingOwner(resource.data.authorId);
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /pestOutbreaks/{outbreakId} {
      allow read: if isSignedIn() && (getRole() == 'Expert' || getRole() == 'Authority');
      allow create, update: if isSignedIn() && (getRole() == 'Expert' || getRole() == 'Authority');
      allow delete: if isSignedIn() && (getRole() == 'Expert' || getRole() == 'Authority');
    }
  }
}
