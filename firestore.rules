rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * KisanMitra Public Demo Rules
     * 
     * CRITICAL: These rules are set to public (allow read, write: if true) 
     * to fulfill the "remove authentication" request and ensure zero 
     * permission errors during the Presidency University presentation.
     */
    match /{document=**} {
      allow read, write: if true;
    }
  }
}