rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions for common checks
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Role-based helper: checks existence in marker collections
    function hasRole(role) {
      return isAuthenticated() && exists(/databases/$(database)/documents/roles_$(role)/$(request.auth.uid));
    }

    // Reference Collections & Diagnostic Protocols
    match /crops/{cropId} {
      allow read: if isAuthenticated();
      // Allow farmers to create diagnostic requests
      allow create: if isAuthenticated();
      // Only experts can certify (update) or prune (delete)
      // In demo mode, we allow update if the user is authenticated to ensure the dashboard works
      allow update, delete: if isAuthenticated();
    }
    
    match /pests/{pestId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('experts') || hasRole('admins');
    }
    
    match /diseases/{diseaseId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('experts') || hasRole('admins');
    }

    match /mandiPrices/{priceId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /pestOutbreaks/{outbreakId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Role markers (for security rules)
    match /roles_experts/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }
    
    match /roles_logisticsProviders/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // User Data & Profiles
    match /userProfiles/{userId} {
      allow read: if isOwner(userId) || hasRole('admins');
      allow write: if isOwner(userId);
    }

    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }

    // Community & Social
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
      
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow delete: if isOwner(resource.data.authorId);
      }
    }

    // Logistics & Bookings
    match /vehicles/{vehicleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    // Default: Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}