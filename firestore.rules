rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * KisanMitra National Grid - Open Mode
     * 
     * Security has been set to PUBLIC for demo and accessibility.
     * All authenticated and unauthenticated users can read and write.
     */
    match /{document=**} {
      allow read, write: if true;
    }
  }
}