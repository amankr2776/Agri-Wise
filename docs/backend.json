
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the AgriWise application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["Expert", "Authority", "Logistics", "Farmer"] },
        "preferredLanguage": { "type": "string" }
      },
      "required": ["id", "role"]
    },
    "Vehicle": {
      "title": "Vehicle",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agencyName": { "type": "string" },
        "type": { "type": "string", "enum": ["Refrigerated Van", "Mini Truck", "Heavy Truck", "Pickup Van"] },
        "plateNumber": { "type": "string" },
        "pricePerKm": { "type": "number" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "currentLat": { "type": "number" },
        "currentLng": { "type": "number" },
        "isAvailable": { "type": "boolean" },
        "contact": { "type": "string" }
      }
    },
    "Booking": {
      "title": "Booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "farmerId": { "type": "string" },
        "vehicleId": { "type": "string" },
        "cropType": { "type": "string" },
        "origin": { "type": "string" },
        "destination": { "type": "string" },
        "distance": { "type": "number" },
        "estimatedFare": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Picked Up", "In Transit", "Reached Destination"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Crop": {
      "title": "Crop",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Plant", "Seed", "Vegetable", "Fruit", "Grain"] },
        "imageUrl": { "type": "string" },
        "diseaseName": { "type": "string" },
        "severity": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
        "description": { "type": "string" },
        "chemicalCure": { "type": "string" },
        "chemicalDosage": { "type": "string" },
        "desiNuskha": { "type": "string" },
        "isCertified": { "type": "boolean" },
        "irrigationInterval": { "type": "integer" },
        "estimatedPrice": { "type": "number" },
        "sowingSeason": { "type": "string" },
        "soilType": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "User", "schema": { "$ref": "#/backend/entities/User" }, "description": "User profile data." }
      },
      {
        "path": "/crops/{cropId}",
        "definition": { "entityName": "Crop", "schema": { "$ref": "#/backend/entities/Crop" }, "description": "Base crop data with treatments." }
      },
      {
        "path": "/vehicles/{vehicleId}",
        "definition": { "entityName": "Vehicle", "schema": { "$ref": "#/backend/entities/Vehicle" }, "description": "Transport vehicles registry." }
      },
      {
        "path": "/bookings/{bookingId}",
        "definition": { "entityName": "Booking", "schema": { "$ref": "#/backend/entities/Booking" }, "description": "Logistics booking records." }
      }
    ]
  }
}
