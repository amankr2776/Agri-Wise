
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the AgriWise application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["Expert", "Authority", "Logistics", "Farmer"] },
        "preferredLanguage": { "type": "string" },
        "expertise": { "type": "string", "description": "e.g., Rice Specialist" },
        "city": { "type": "string" },
        "state": { "type": "string" }
      },
      "required": ["id", "role"]
    },
    "Crop": {
      "title": "Crop",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Plant", "Seed", "Vegetable", "Fruit", "Grain"] },
        "diseaseName": { "type": "string" },
        "severity": { "type": "string", "enum": ["Critical", "High", "Medium", "Low"] },
        "chemicalCure": { "type": "string" },
        "chemicalDosage": { "type": "string" },
        "desiNuskha": { "type": "string" },
        "symptoms": { "type": "string" },
        "isCertified": { "type": "boolean" },
        "imageUrl": { "type": "string" },
        "irrigationInterval": { "type": "integer", "description": "Days between watering" },
        "estimatedMarketPrice": { "type": "number", "description": "Price in INR per Quintal" },
        "sowingSeason": { "type": "string" },
        "soilType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Post": {
      "title": "Post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorRole": { "type": "string" },
        "authorExpertise": { "type": "string" },
        "authorLocation": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string", "enum": ["Success Story", "Issue Alert", "Product Feedback", "General Update"] },
        "likesCount": { "type": "integer" },
        "reactions": { "type": "object", "description": "JSON mapping of reaction type to count" },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "PestOutbreak": {
      "title": "Pest Outbreak",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "pestName": { "type": "string" },
        "state": { "type": "string" },
        "severity": { "type": "string", "enum": ["Critical", "Warning", "Info"] },
        "areaHectares": { "type": "number" },
        "predictedMovementVector": { "type": "string" },
        "containmentStrategy": { "type": "string" },
        "reportedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "User", "schema": { "$ref": "#/backend/entities/User" }, "description": "User profile data." }
      },
      {
        "path": "/crops/{cropId}",
        "definition": { "entityName": "Crop", "schema": { "$ref": "#/backend/entities/Crop" }, "description": "Professional agricultural registry." }
      },
      {
        "path": "/posts/{postId}",
        "definition": { "entityName": "Post", "schema": { "$ref": "#/backend/entities/Post" }, "description": "Community posts." }
      },
      {
        "path": "/pestOutbreaks/{outbreakId}",
        "definition": { "entityName": "PestOutbreak", "schema": { "$ref": "#/backend/entities/PestOutbreak" }, "description": "Bio-security alerts." }
      }
    ]
  }
}
