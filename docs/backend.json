
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the AgriWise application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["Expert", "Authority", "Logistics", "Farmer"] },
        "preferredLanguage": { "type": "string" }
      },
      "required": ["id", "role"]
    },
    "Crop": {
      "title": "Crop",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Plant", "Seed", "Vegetable", "Fruit", "Grain"] },
        "imageUrl": { "type": "string" },
        "diseaseName": { "type": "string" },
        "severity": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
        "description": { "type": "string" },
        "chemicalCure": { "type": "string" },
        "chemicalDosage": { "type": "string" },
        "desiNuskha": { "type": "string" },
        "isCertified": { "type": "boolean" },
        "irrigationInterval": { "type": "integer", "description": "Interval in days between irrigation cycles." },
        "estimatedPrice": { "type": "number", "description": "Current market price in INR per quintal." },
        "sowingSeason": { "type": "string" },
        "soilType": { "type": "string" }
      }
    },
    "PestOutbreak": {
      "title": "Pest Outbreak",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "pestName": { "type": "string" },
        "cropType": { "type": "string" },
        "severity": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "state": { "type": "string" },
        "reportedAt": { "type": "string", "format": "date-time" },
        "predictedMovementVector": { "type": "string" }
      }
    },
    "CropCertification": {
      "title": "Crop Certification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "cropName": { "type": "string" },
        "majorPest": { "type": "string" },
        "traditionalRemedy": { "type": "string" },
        "isCertified": { "type": "boolean" },
        "region": { "type": "string" },
        "expertId": { "type": "string" }
      }
    },
    "SoilData": {
      "title": "Soil Data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "phLevel": { "type": "number" },
        "moisturePercentage": { "type": "number" },
        "recordedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "User", "schema": { "$ref": "#/backend/entities/User" }, "description": "User profile data." }
      },
      {
        "path": "/crops/{cropId}",
        "definition": { "entityName": "Crop", "schema": { "$ref": "#/backend/entities/Crop" }, "description": "Base crop data with treatments." }
      },
      {
        "path": "/pestOutbreaks/{outbreakId}",
        "definition": { "entityName": "PestOutbreak", "schema": { "$ref": "#/backend/entities/PestOutbreak" }, "description": "Real-time pest outbreak reports." }
      },
      {
        "path": "/cropCertifications/{certId}",
        "definition": { "entityName": "CropCertification", "schema": { "$ref": "#/backend/entities/CropCertification" }, "description": "Records of crop certification status." }
      },
      {
        "path": "/users/{userId}/soilHealth/{dataId}",
        "definition": { "entityName": "SoilData", "schema": { "$ref": "#/backend/entities/SoilData" }, "description": "Soil health records." }
      }
    ]
  }
}
