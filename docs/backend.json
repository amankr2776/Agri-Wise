{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the AgriWise application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["Expert", "Authority", "Logistics", "Farmer"] },
        "preferredLanguage": { "type": "string" },
        "expertise": { "type": "string", "description": "e.g., Rice Specialist" },
        "city": { "type": "string" },
        "state": { "type": "string" }
      },
      "required": ["id", "role"]
    },
    "Post": {
      "title": "Post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorRole": { "type": "string" },
        "authorExpertise": { "type": "string" },
        "authorLocation": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string", "enum": ["Success Story", "Issue Alert", "Product Feedback", "General Update"] },
        "likesCount": { "type": "integer" },
        "reactions": { "type": "object", "description": "JSON mapping of reaction type to count" },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Comment": {
      "title": "Comment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "parentId": { "type": "string", "description": "For nested replies" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Feedback": {
      "title": "Feedback",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "targetId": { "type": "string", "description": "ID of Agency or Product" },
        "targetType": { "type": "string", "enum": ["Agency", "Product"] },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "User", "schema": { "$ref": "#/backend/entities/User" }, "description": "User profile data." }
      },
      {
        "path": "/posts/{postId}",
        "definition": { "entityName": "Post", "schema": { "$ref": "#/backend/entities/Post" }, "description": "Community posts." }
      },
      {
        "path": "/posts/{postId}/comments/{commentId}",
        "definition": { "entityName": "Comment", "schema": { "$ref": "#/backend/entities/Comment" }, "description": "Post comments." }
      },
      {
        "path": "/feedback/{feedbackId}",
        "definition": { "entityName": "Feedback", "schema": { "$ref": "#/backend/entities/Feedback" }, "description": "User reviews." }
      }
    ]
  }
}