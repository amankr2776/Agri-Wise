
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the AgriWise application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["Expert", "Authority", "Logistics", "Farmer"] },
        "preferredLanguage": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "phone": { "type": "string" },
        "basePrice": { "type": "number", "description": "Default price per KM for logistics providers" }
      },
      "required": ["id", "role"]
    },
    "Vehicle": {
      "title": "Vehicle",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "agencyName": { "type": "string" },
        "type": { "type": "string", "enum": ["Mini Truck (2T)", "Heavy Truck (15T)", "Pickup Van (1T)", "Refrigerated Van (5T)", "Tractor Trailer (8T)"] },
        "plateNumber": { "type": "string" },
        "pricePerKm": { "type": "number" },
        "contact": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "isAvailable": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Booking": {
      "title": "Booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "farmerId": { "type": "string" },
        "vehicleId": { "type": "string" },
        "agencyName": { "type": "string" },
        "cropType": { "type": "string" },
        "distance": { "type": "number" },
        "estimatedFare": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Picked Up", "In Transit", "Reached Destination"] },
        "destination": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "User", "schema": { "$ref": "#/backend/entities/User" }, "description": "User profile data." }
      },
      {
        "path": "/vehicles/{vehicleId}",
        "definition": { "entityName": "Vehicle", "schema": { "$ref": "#/backend/entities/Vehicle" }, "description": "Logistics fleet inventory." }
      },
      {
        "path": "/bookings/{bookingId}",
        "definition": { "entityName": "Booking", "schema": { "$ref": "#/backend/entities/Booking" }, "description": "Shipment transactions." }
      }
    ]
  }
}
