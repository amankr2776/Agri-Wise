
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the AgriWise application, encompassing various roles such as Farmer, Expert, Government Authority, or Logistics Provider.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "The user's email address, used for identification and communication.",
          "format": "email"
        },
        "mobileNumber": {
          "type": "string",
          "description": "The user's mobile phone number."
        },
        "firstName": {
          "type": "string",
          "description": "The first name of the user."
        },
        "lastName": {
          "type": "string",
          "description": "The last name of the user."
        },
        "role": {
          "type": "string",
          "description": "The primary role of the user (e.g., Farmer, Expert, Authority, Logistics).",
          "enum": ["Farmer", "Expert", "Authority", "Logistics"]
        },
        "preferredLanguage": {
          "type": "string",
          "description": "The user's preferred language (e.g., English, Hindi, Punjabi, Bengali)."
        },
        "registrationDate": {
          "type": "string",
          "description": "Registration date.",
          "format": "date-time"
        }
      },
      "required": ["id", "role", "preferredLanguage"]
    },
    "PestOutbreak": {
      "title": "Pest Outbreak",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "pestName": { "type": "string" },
        "cropType": { "type": "string" },
        "severity": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "state": { "type": "string" },
        "reportedAt": { "type": "string", "format": "date-time" }
      }
    },
    "CropCertification": {
      "title": "Crop Certification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "cropName": { "type": "string" },
        "isCertified": { "type": "boolean" },
        "region": { "type": "string" },
        "expertId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "phone"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "User profile data."
        }
      },
      {
        "path": "/pestOutbreaks/{outbreakId}",
        "definition": {
          "entityName": "PestOutbreak",
          "schema": { "$ref": "#/backend/entities/PestOutbreak" },
          "description": "Real-time pest outbreak reports with geographic coordinates."
        }
      },
      {
        "path": "/cropCertifications/{certId}",
        "definition": {
          "entityName": "CropCertification",
          "schema": { "$ref": "#/backend/entities/CropCertification" },
          "description": "Records of crop certification status across India."
        }
      }
    ]
  }
}
